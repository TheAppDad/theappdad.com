# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon (or any Postgres): Dashboard → connect → copy pooled URI
DATABASE_URL=postgresql://user:pass@ep-....neon.tech/neondb?sslmode=require

# Recommended for local dev (middleware redirects + return URLs)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Site URL (emails + cron links). On Vercel, VERCEL_URL is set automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Daily cron: Authorization: Bearer <CRON_SECRET> (Vercel sets this when you add CRON_SECRET in project env)
CRON_SECRET=generate-a-long-random-string

# Optional: 15-day export follow-up emails (https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=App Dads <onboarding@yourdomain.com>
